# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/bmrms
MONGODB_TEST_URI=mongodb://localhost:27017/bmrms_test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
IPFS_GATEWAY=http://localhost:8080/ipfs/

# Blockchain Configuration
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=sepolia
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
BLOCKCHAIN_CHAIN_ID=11155111
BLOCKCHAIN_PRIVATE_KEY=your-metamask-private-key
CONSENT_CONTRACT_ADDRESS=0x_after_deployment
RECORD_CONTRACT_ADDRESS=0x_after_deployment
AUDIT_CONTRACT_ADDRESS=0x_after_deployment

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here
ENCRYPTION_ALGORITHM=aes-256-gcm

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,dcm,dicom

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated browser origins (your Vercel app URL(s), plus localhost for dev)
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
# Set true only when you explicitly want to allow all origins (development/troubleshooting)
CORS_ALLOW_ALL=false
# Set true to allow any https://*.vercel.app origin (preview deployments)
CORS_ALLOW_VERCEL_PREVIEWS=true

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Offline Sync
SYNC_BATCH_SIZE=50
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=5000
